# ─────────────────────────────────────────────────────────────
# Variables de entorno — configurar en Netlify (team Dcycle) y en local (.env.local)
# NUNCA commitear valores reales. Los secretos van en env de Netlify / Supabase Vault.
# ─────────────────────────────────────────────────────────────

# Supabase (Postgres + Auth)
# Proyecto: https://cwcvurrkqwifpngzecxu.supabase.co
# La URL la dejamos publicada (no es secreta). Las keys SÍ son secretas.
NEXT_PUBLIC_SUPABASE_URL=https://cwcvurrkqwifpngzecxu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supermetrics API — ingesta de paid (LinkedIn Ads LIA + Google Ads AW).
# LinkedIn/Google ya están AUTENTICADOS en Supermetrics; falta el token de API.
SUPERMETRICS_API_KEY=
SUPERMETRICS_TEAM_ID=

# HubSpot — Private App token (server-side). Scopes mínimos en PRD §6.1.
HUBSPOT_PRIVATE_APP_TOKEN=

# Google Workspace SSO (OIDC) — vía Supabase Auth. Pendiente.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Marca operativa: si se pone a "true" la app fuerza fallback a mock incluso si
# Supabase está configurado (útil para previews protegidos de Ops/dev).
FORCE_MOCK=
