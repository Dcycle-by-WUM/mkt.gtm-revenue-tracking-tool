# ─────────────────────────────────────────────────────────────
# Variables de entorno — configurar en Netlify (team Dcycle) y en local (.env.local)
# NUNCA commitear valores reales. Los secretos van en env de Netlify / Supabase Vault.
# ─────────────────────────────────────────────────────────────

# Supabase (Postgres + Auth) — pendiente de crear el proyecto
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supermetrics API — ingesta de paid (LinkedIn Ads LIA + Google Ads AW)
# LinkedIn/Google ya están AUTENTICADOS en Supermetrics; falta el token de API.
SUPERMETRICS_API_KEY=
SUPERMETRICS_TEAM_ID=

# Google Workspace SSO (OIDC) — vía Supabase Auth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# HubSpot — BLOQUEADO: API key pendiente (§12.1 del brief). No usar todavía.
HUBSPOT_PRIVATE_APP_TOKEN=
